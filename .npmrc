# pnpm config for the root workspace.
#
# @heroui/react re-exports ~48 sibling @heroui/* subpackages from its
# dist/index.mjs. The playground (Next.js, in ./playground) compiles
# ../src via experimental externalDir, so its webpack walks up to the
# root node_modules looking for those subpackages.
#
# pnpm's default isolated layout keeps transitive deps inside
# node_modules/.pnpm/, which webpack module resolution will not follow.
# Hoisting all @heroui/* to the public node_modules makes them visible
# to playground's webpack without inflating root deps with 48 explicit
# pins.
public-hoist-pattern[]=@heroui/*
