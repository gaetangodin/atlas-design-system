{
  "name": "@atlas/design-system",
  "version": "0.1.0",
  "description": "Atlas — HeroUI components themed with the Xeekrs design language, in a layered architecture.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/domain/tokens/index.d.ts",
      "import": "./dist/domain/tokens/index.js"
    },
    "./tailwind": {
      "types": "./dist/infrastructure/tailwind/preset.d.ts",
      "import": "./dist/infrastructure/tailwind/preset.js"
    },
    "./theme": {
      "types": "./dist/infrastructure/heroui/xeekrs-theme.d.ts",
      "import": "./dist/infrastructure/heroui/xeekrs-theme.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-styles.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,md,json}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs:gen": "node scripts/gen-component-docs.mjs",
    "deploy:storybook": "pnpm build-storybook && netlify deploy --dir=storybook-static --prod"
  },
  "peerDependencies": {
    "embla-carousel-react": ">=8.0.0",
    "framer-motion": ">=11.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "recharts": ">=2.12.0",
    "sonner": ">=2.0.0",
    "tailwindcss": "^3.4.0",
    "vaul": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "vaul": {
      "optional": true
    },
    "sonner": {
      "optional": true
    },
    "recharts": {
      "optional": true
    },
    "embla-carousel-react": {
      "optional": true
    }
  },
  "dependencies": {
    "@heroui/react": "^2.7.0",
    "@heroui/system": "^2.4.0",
    "@heroui/theme": "^2.4.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.383.0",
    "react-resizable-panels": "^4.11.2",
    "tailwind-merge": "^2.6.0",
    "tailwind-variants": "^0.2.1"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.4.0",
    "autoprefixer": "^10.4.0",
    "embla-carousel-react": "^8.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "framer-motion": "^11.0.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.15.0",
    "sonner": "^2.0.0",
    "storybook": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vaul": "^1.1.0",
    "vite": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gaetangodin/atlas-design-system.git"
  }
}
